{
  "expo": {
    "name": "FrontEnd",
    "slug": "frontend",

    "version": "1.0.0",

    "orientation": "portrait",

    "scheme": "frontend",

    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "predictiveBackGestureEnabled": false
    },

    "plugins": [
      "expo-router"
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}